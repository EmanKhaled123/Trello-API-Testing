      "name": "Create a Board",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Response has an ID\", function () {\r",
              "const json= pm.response.json();\r",
              "pm.expect(json.id).to.not.be.null; \r",
              "});\r",
              "\r",
