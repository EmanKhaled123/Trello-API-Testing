    {
      "name": "Getting Lists on Board",
      "event": [
        {
          "listen": "test",
          "script": {
            "exec": [
              "pm.test(\"Check if the response contains the correct list names\", function () {\r",
              "    const json= pm.response.json();\r",
              "   json.forEach(function(list) {\r",
              "    if (list.name == \"To Do\") {\r",
              "        pm.environment.set(\"ToDoListId\", list.id);}\r",
              "    else if (list.name == \"Doing\") {\r",
              "        pm.environment.set(\"DoingListId\", list.id);}\r",
              "    else if (list.name == \"Done\") {\r",
              "        pm.environment.set(\"DoneListId\", list.id);}\r",
              "});\r",
              "});"
            ],
            "type": "text/javascript",
            "packages": {},
            "requests": {}
          }
        }
      ],
